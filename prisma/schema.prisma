datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String             @id            // Firebase UID
  email        String             @unique
  createdAt    DateTime           @default(now())
  diaryDays    DiaryDay[]
  settings     UserSettings?
  weights      WeightEntry[]
  checkpoints  WeightCheckpoint[]
  customFoods      CustomFood[]
  savedMeals       SavedMeal[]
  activities       Activity[]
  workoutNotes     WorkoutNote[]
  supplements      Supplement[]
  measurements     BodyMeasurement[]
  targetSnapshots  TargetSnapshot[]
}

model DiaryDay {
  id     Int    @id @default(autoincrement())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String                              // YYYY-MM-DD
  items  Json   @default("{}")              // Record<mealName, FoodItem[]>
  hunger Int?
  mood   Int?
  water  Int?
  steps  Int?

  @@unique([userId, date])
  @@index([userId])
}

model UserSettings {
  userId          String  @id
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kcal            Float   @default(0)
  protein         Float   @default(0)
  carbs           Float   @default(0)
  fat             Float   @default(0)
  satfat          Float   @default(0)
  fiber           Float   @default(0)
  waterTarget     Int     @default(8)
  meals           Json    @default("[]")    // string[]
  mealTimes       Json    @default("{}")    // Record<string, string>
  sheetsUrl       String  @default("")
  lang            String  @default("it")
  weightHidden    Boolean @default(false)
  wizardCompleted Boolean @default(false)
  startWeight      Float?
  goalWeight       Float?
  weightObjective  String?
  goalDate         String?
}

model WeightEntry {
  id     Int     @id @default(autoincrement())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String                              // YYYY-MM-DD
  weight Float
  note   String?

  @@unique([userId, date])
  @@index([userId])
}

model WeightCheckpoint {
  id           String   @id                  // timestamp-based, generato dal client
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         String                        // YYYY-MM-DD
  targetWeight Float
  label        String?
  benefits     String[] @default([])

  @@index([userId])
}

model CustomFood {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  brand     String?
  per100g   Json                             // { kcal, protein, carbs, fat, satfat, fiber }
  createdAt DateTime @default(now())

  @@index([userId])
}

model SavedMeal {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  items     Json                             // FoodItem[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model Activity {
  id          String   @id                  // UUID generato dal client
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String                        // YYYY-MM-DD
  time        String?                       // HH:MM
  type        String                        // corsa | camminata | bici | palestra | nuoto | yoga | trekking | custom
  name        String
  icon        String
  color       String
  duration    Int                           // minuti
  intensity   String                        // leggera | media | intensa
  distance    Float?                        // km (opzionale)
  kcal        Int
  addToBudget Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model WorkoutNote {
  id        String   @id                  // UUID generato dal client
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String                        // YYYY-MM-DD
  title     String?                       // es. "Giorno A - Push"
  exercises Json                          // WorkoutExercise[]
  notes     String?                       // note libere
  createdAt DateTime @default(now())

  @@index([userId])
}

model Supplement {
  id        String   @id                  // UUID generato dal client
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String                        // YYYY-MM-DD
  time      String?                       // HH:MM
  kind      String                        // farmaco | integratore
  name      String
  quantity  Float
  unit      String                        // mg | ml | g
  kcal      Float?                        // opzionale, solo integratori
  createdAt DateTime @default(now())

  @@index([userId])
}

model BodyMeasurement {
  id        String   @id                  // UUID generato dal client
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String                        // YYYY-MM-DD
  type      String                        // vita | fianchi | petto | bicipite | coscia | collo | spalle | polpaccio | grasso_corp | massa_musc | idratazione | freq_riposo | pressione_sis | pressione_dia | peso
  value     Float
  unit      String                        // cm | % | bpm | mmHg | kg
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model TargetSnapshot {
  id            Int      @id @default(autoincrement())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectiveDate String                        // YYYY-MM-DD — giorno da cui questi target sono in vigore
  kcal          Float
  protein       Float
  carbs         Float
  fat           Float
  satfat        Float
  fiber         Float
  createdAt     DateTime @default(now())

  @@unique([userId, effectiveDate])
  @@index([userId])
}

model Exercise {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  name             String
  primaryMuscles   String[]
  secondaryMuscles String[]
  equipment        String[]
  movementPattern  String[]
  difficulty       String
  durationSeconds  Float
  tags             String[]
  translations     Json     @default("{}")
  posterUrl        String
  videoUrl         String
  createdAt        DateTime @default(now())

  @@index([slug])
}

model FoodSearchMiss {
  id          Int      @id @default(autoincrement())
  query       String                       // termine cercato (lowercase, trimmed)
  commonCount Int      @default(0)         // risultati locali trovati
  remoteCount Int      @default(0)         // risultati WFA trovati
  createdAt   DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}
